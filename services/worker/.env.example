# Lima Worker — example environment variables

ENV=development
SERVICE_NAME=lima-worker

DATABASE_URL=postgres://lima:lima_dev_secret@localhost:5444/lima?sslmode=disable
REDIS_URL=redis://localhost:6380

OTEL_ENDPOINT=http://localhost:4318

# Must match the API's CREDENTIALS_ENCRYPTION_KEY so the worker can decrypt
# per-user AI provider credentials stored by the API.
CREDENTIALS_ENCRYPTION_KEY=dev_credentials_key_change_in_prod

GENERATION_WORKERS=4
SCHEMA_WORKERS=2
IMPORT_WORKERS=2

# AI provider, model, and user credentials are configured per user through the
# app settings UI. The worker no longer uses a single global LLM configuration.

# Optional: override the model used specifically for the AI connector-draft job.
# Use a model with a large context window — the job sends full API documentation.
# Example: gpt-4.5, gpt-4-turbo, o3
# CONNECTOR_DRAFT_MODEL=gpt-4.5

# Optional: Tavily MCP endpoint (include your API key in the URL).
# When set, the GitHub Copilot generation agent gains a web-search tool so it
# can look up API base URLs and documentation without asking the user.
# TAVILY_MCP_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=<your-key-here>
