# Lima Worker — example environment variables

ENV=development
SERVICE_NAME=lima-worker

DATABASE_URL=postgres://lima:lima_dev_secret@localhost:5432/lima?sslmode=disable
REDIS_URL=redis://localhost:6379

OTEL_ENDPOINT=http://localhost:4318

# Must match the API's CREDENTIALS_ENCRYPTION_KEY so the worker can decrypt
# per-user AI provider credentials stored by the API.
CREDENTIALS_ENCRYPTION_KEY=dev_credentials_key_change_in_prod

GENERATION_WORKERS=4
SCHEMA_WORKERS=2
IMPORT_WORKERS=2

# AI provider, model, and user credentials are configured per user through the
# app settings UI. The worker no longer uses a single global LLM configuration.
