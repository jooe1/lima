# Lima API — example environment variables
# Copy to .env and fill in values for local development.

ENV=development
PORT=8080
SERVICE_NAME=lima-api

DATABASE_URL=postgres://lima:lima_dev_secret@localhost:5444/lima?sslmode=disable
REDIS_URL=redis://localhost:6380

# OTEL collector endpoint (docker-compose: http://localhost:4318)
OTEL_ENDPOINT=http://localhost:4318

# Must be a long random string in production
JWT_SECRET=dev_jwt_secret_change_in_prod

# Shared symmetric key used to encrypt per-user AI provider credentials.
# Set the same value in the API and worker environments.
CREDENTIALS_ENCRYPTION_KEY=dev_credentials_key_change_in_prod

# Comma-separated list of allowed CORS origins
ALLOW_ORIGINS=http://localhost:3000

OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/v1/auth/sso/callback
# Required when the OIDC provider allows consumer email domains (gmail, outlook, etc.).
# Leave blank to auto-derive from the user's email domain (safe for private corporate domains only).
OIDC_COMPANY_SLUG=
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional — for teams using Google accounts)
# Create an OAuth 2.0 client at https://console.cloud.google.com/apis/credentials
# Add http://localhost:8080/v1/auth/google/callback as an authorised redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback
GOOGLE_COMPANY_SLUG=

# Email magic link (optional — passwordless email login for any email address)
# In development, links are printed to the API console (no SMTP required).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
DEFAULT_COMPANY_SLUG=
