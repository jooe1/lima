# Lima API — example environment variables
# Copy to .env and fill in values for local development.

ENV=development
PORT=8080
SERVICE_NAME=lima-api

DATABASE_URL=postgres://lima:lima_dev_secret@localhost:5444/lima?sslmode=disable
REDIS_URL=redis://localhost:6380

# OTEL collector endpoint (docker-compose: http://localhost:4318)
OTEL_ENDPOINT=http://localhost:4318

# Must be a long random string in production
JWT_SECRET=dev_jwt_secret_change_in_prod

# Shared symmetric key used to encrypt per-user AI provider credentials.
# Set the same value in the API and worker environments.
CREDENTIALS_ENCRYPTION_KEY=dev_credentials_key_change_in_prod

# Comma-separated list of allowed CORS origins
ALLOW_ORIGINS=http://localhost:3000
