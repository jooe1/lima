# Lima Web — example environment variables

# URL the Next.js rewrite proxy will forward /api/v1/* to
API_BASE_URL=http://localhost:8080

# Set to "true" to show the dev login form (email/name/company bypass).
# Works in both `next dev` and Docker/production builds.
NEXT_PUBLIC_DEV_LOGIN=true

# Google OAuth — set to true to show the "Continue with Google" button
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Pre-configured company slug for magic link (hides the company slug field in the login form)
NEXT_PUBLIC_DEFAULT_COMPANY_SLUG=
